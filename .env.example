# ============================================================
# QC Monitoring System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   php artisan key:generate
# ============================================================

APP_NAME="QC Monitor"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://your-domain.com

# ============================================================
# Logging
# ============================================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================================
# Database — MySQL
# ============================================================
# Docker: DB_HOST=mysql
# Local:  DB_HOST=127.0.0.1
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=qc_monitoring
DB_USERNAME=
DB_PASSWORD=

# ============================================================
# Cache & Session — Redis (Recommended for Production)
# ============================================================
# Docker: REDIS_HOST=redis
# Local:  REDIS_HOST=127.0.0.1
CACHE_DRIVER=redis
CACHE_PREFIX=qc_
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# ============================================================
# Queue
# ============================================================
QUEUE_CONNECTION=database

# ============================================================
# Filesystem
# ============================================================
FILESYSTEM_DISK=local
BROADCAST_DRIVER=log

# ============================================================
# Seeder — Admin Credentials (Change after deploy!)
# ============================================================
SEED_ADMIN_PASSWORD=

# ============================================================
# Mail (Optional — for future notifications)
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
